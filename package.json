{
  "name": "lattice",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @lattice/studio test:e2e",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm run build:core && pnpm --parallel --filter @lattice/api --filter @lattice/studio dev",
    "build:core": "pnpm --filter @lattice/contracts build && pnpm --filter @lattice/importer-core build && pnpm --filter @lattice/compiler-core build",
    "generate:ontologies": "node scripts/generate-industry-ontologies.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
