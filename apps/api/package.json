{
  "name": "@lattice/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "dev": "node --watch dist/server.js",
