# Vercel Marketplace injects these automatically for the Lattice API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Vercel Marketplace also injects these browser-safe values. Vite is configured
# to expose NEXT_PUBLIC_ variables as well as its native VITE_ prefix.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Server-only database values are also injected by the integration. POSTGRES_URL
# is for pooled runtime access; POSTGRES_URL_NON_POOLING is for migrations/admin.
POSTGRES_URL=postgresql://replace_me
POSTGRES_URL_NON_POOLING=postgresql://replace_me

# Optional local aliases supported by Lattice when not using Vercel Marketplace:
# LATTICE_SUPABASE_URL=https://your-project-ref.supabase.co
# LATTICE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Existing deployment settings
LATTICE_STUDIO_ORIGIN=https://lattice.example.com
VITE_API_URL=https://api.lattice.example.com
